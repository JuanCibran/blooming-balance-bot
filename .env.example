# Opción A: path al JSON (uso local)
GOOGLE_APPLICATION_CREDENTIALS=path/to/service_account.json

# Opción B: contenido del JSON como string (uso en Railway)
# GOOGLE_CREDENTIALS_JSON={"type":"service_account","project_id":...}
